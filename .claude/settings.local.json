{
  "permissions": {
    "allow": [
      "WebSearch",
      "Skill(gsd:execute-phase)",
      "WebFetch(domain:*)",
      "Skill(gsd:insert-phase)",
      "WebFetch(domain:wiki.loxberry.de)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/bash-allow.cjs"
          }
        ]
      }
    ]
  }
}
